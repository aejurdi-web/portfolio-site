---
const navItems = [
  { href: '/research', label: 'Research' },
  { href: '/tools/yield', label: 'Yield Calculator' },
  { href: '/writing', label: 'Writing' },
  { href: '/about', label: 'About' },
];
---

<header class="border-b border-hairline">
	<div class="mx-auto flex max-w-5xl items-center justify-between px-6 py-4">
		<a href="/" class="font-display text-lg font-semibold tracking-tight text-ink">
			Adam Jurdi
		</a>
		<nav class="flex gap-6 font-mono text-xs uppercase tracking-wide text-slate">
			{navItems.map((item) => (
				<a href={item.href} class="transition-colors hover:text-copper">{item.label}</a>
			))}
		</nav>
	</div>
</header>
