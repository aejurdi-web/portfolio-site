---
const navItems = [
  { href: '/research', label: 'Research' },
  { href: '/venture', label: 'Venture' },
  { href: '/writing', label: 'Writing' },
  { href: '/tools/yield', label: 'Yield Calculator' },
  { href: '/about', label: 'About' },
];
---

<header class="border-b border-border bg-surface">
	<div class="mx-auto flex max-w-5xl items-center justify-between px-6 py-4">
		<a href="/" class="flex items-center gap-2.5 font-display text-lg font-semibold tracking-tight text-ink">
			<img src="/favicon.svg" alt="" aria-hidden="true" class="h-5 w-auto" />
			Adam Jurdi
		</a>
		<nav class="flex gap-6 font-mono text-xs uppercase tracking-wide text-muted">
			{navItems.map((item) => (
				<a href={item.href} class="transition-colors hover:text-accent">{item.label}</a>
			))}
		</nav>
	</div>
</header>
