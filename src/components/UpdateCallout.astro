---
interface Props {
	label: string;
}

const { label } = Astro.props as Props;
---

<div class="not-prose mb-10 border border-accent/30 bg-accent/[0.06] px-5 py-4 [&_p]:mt-3 [&_p]:text-sm [&_p]:leading-relaxed [&_p]:text-ink [&_p:first-of-type]:mt-0">
	<p class="font-mono text-xs uppercase tracking-[0.2em] text-accent">{label}</p>
	<slot />
</div>
