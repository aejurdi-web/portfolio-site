---
import Layout from '../layouts/Layout.astro';
---

<Layout title="About — Adam Jurdi">
	<section class="mx-auto max-w-3xl px-6 py-20">
		<p class="font-mono text-xs uppercase tracking-[0.2em] text-copper">About</p>
		<h1 class="mt-4 font-display text-4xl font-semibold tracking-tight text-ink">Adam Jurdi</h1>
		<p class="mt-6 max-w-xl text-lg italic text-slate">
			[Background and what draws you to semiconductor equity research — 2–3 sentences.]
		</p>

		<div class="mt-16 grid gap-12 sm:grid-cols-2">
			<div>
				<h2 class="font-mono text-xs uppercase tracking-wide text-slate">Credentials</h2>
				<ul class="mt-4 space-y-3 border-t border-hairline pt-4">
					<li class="flex items-baseline justify-between gap-4">
						<span class="text-ink">SIE (Securities Industry Essentials)</span>
						<span class="font-mono text-xs italic text-slate">[status / date]</span>
					</li>
				</ul>
			</div>
			<div>
				<h2 class="font-mono text-xs uppercase tracking-wide text-slate">Education</h2>
				<ul class="mt-4 space-y-3 border-t border-hairline pt-4">
					<li class="flex flex-col">
						<span class="text-ink">[Degree, Major]</span>
						<span class="font-mono text-xs italic text-slate">[Institution, Year]</span>
					</li>
				</ul>
			</div>
		</div>

		<div class="mt-16 border-t border-hairline pt-8">
			<a
				href="/resume.pdf"
				class="inline-flex items-center gap-2 rounded-full border border-ink px-5 py-2 font-mono text-xs uppercase tracking-wide text-ink transition-colors hover:bg-ink hover:text-paper"
			>
				Download résumé <span aria-hidden="true">↓</span>
			</a>
		</div>
	</section>
</Layout>
