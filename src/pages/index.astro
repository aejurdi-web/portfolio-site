---
import Layout from '../layouts/Layout.astro';
import WaferGrid from '../components/WaferGrid.astro';

const pillars = [
  {
    eyebrow: 'Written theses',
    title: 'Research',
    description: "Equity theses on technology companies, written the way I'd want to read them.",
    href: '/research',
  },
  {
    eyebrow: 'Interactive tool',
    title: 'Yield / Chiplet Economics Calculator',
    description: 'Model die yield and chiplet economics, the manufacturing math behind technology company margins.',
    href: '/tools/yield',
  },
  {
    eyebrow: 'Explainers',
    title: 'Writing',
    description: 'Technology fundamentals translated into what it means for the investment case.',
    href: '/writing',
  },
];
---

<Layout title="Adam Jurdi: Equity Research, Semiconductors">
	<section class="mx-auto max-w-5xl px-6 py-20 lg:py-28">
		<div class="grid gap-12 lg:grid-cols-[1.1fr_0.9fr] lg:items-center">
			<div>
				<p class="font-mono text-xs uppercase tracking-[0.2em] text-accent">
					Equity Research, Technology
				</p>
				<h1 class="mt-4 font-display text-5xl font-semibold tracking-tight text-ink sm:text-6xl">
					Adam Jurdi<span class="hero-cursor" aria-hidden="true">_</span>
				</h1>
				<p class="mt-6 max-w-md text-lg text-muted">
					Equity research built from the wafer up, translating process nodes, packaging, and
					yield economics into the assumptions that move semiconductor stocks.
				</p>
				<div class="mt-8 flex flex-wrap gap-3 font-mono text-xs uppercase tracking-wide text-muted">
					<span class="rounded-full border border-border px-3 py-1">Coverage: Technology</span>
					<span class="rounded-full border border-border px-3 py-1">Focus: Equity Research</span>
				</div>
			</div>
			<WaferGrid class="w-full" />
		</div>
	</section>

	<section class="border-t border-border">
		<div class="mx-auto max-w-5xl px-6 py-16">
			<div class="grid overflow-hidden rounded-lg border border-border bg-surface sm:grid-cols-3">
				{pillars.map((pillar, i) => (
					<a
						href={pillar.href}
						class:list={[
							'group p-8 transition-colors hover:bg-ink/[0.03]',
							i > 0 && 'border-t border-border sm:border-l sm:border-t-0',
						]}
					>
						<p class="font-mono text-xs uppercase tracking-wide text-accent">{pillar.eyebrow}</p>
						<h2 class="mt-3 font-display text-xl font-semibold tracking-tight text-ink">
							{pillar.title}
						</h2>
						<p class="mt-3 text-sm text-muted">{pillar.description}</p>
						<p class="mt-6 font-mono text-xs uppercase tracking-wide text-ink">
							View
							<span class="inline-block transition-transform group-hover:translate-x-1">→</span>
						</p>
					</a>
				))}
			</div>
		</div>
	</section>

</Layout>
