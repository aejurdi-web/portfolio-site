---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const entries = (await getCollection('research', ({ data }) => !data.draft)).sort(
	(a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);
---

<Layout title="Research">
	<main class="mx-auto max-w-2xl px-6 py-24">
		<h1 class="text-2xl font-semibold">Research</h1>
		<ul class="mt-6 space-y-4">
			{entries.map((entry) => (
				<li>
					<a class="text-slate-900 underline" href={`/research/${entry.id}`}>{entry.data.title}</a>
				</li>
			))}
		</ul>
	</main>
</Layout>
