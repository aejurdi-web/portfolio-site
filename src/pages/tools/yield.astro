---
import Layout from '../../layouts/Layout.astro';
import YieldCalculator from '../../components/YieldCalculator';
---

<Layout title="Yield Calculator — Adam Jurdi">
	<section class="mx-auto max-w-3xl px-6 py-20">
		<p class="font-mono text-xs uppercase tracking-[0.2em] text-accent">Interactive Tool</p>
		<h1 class="mt-4 font-display text-4xl font-semibold tracking-tight text-ink">
			Yield / Chiplet Economics Calculator
		</h1>
		<p class="mt-4 max-w-xl text-muted">
			Model die yield and chiplet economics against a visual wafer map. Coming in Phase 2.
		</p>
		<div class="mt-12 border-t border-border pt-10">
			<YieldCalculator client:load />
		</div>
	</section>
</Layout>
