---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const entries = (await getCollection('venture', ({ data }) => !data.draft)).sort(
	(a, b) =>
		b.data.date.valueOf() - a.data.date.valueOf() ||
		(a.data.order ?? Infinity) - (b.data.order ?? Infinity) ||
		a.id.localeCompare(b.id)
);

function companyName(title: string) {
	return title.split(':')[0].trim();
}
---

<Layout title="Adam Jurdi: Venture">
	<section class="mx-auto max-w-5xl px-6 py-20">
		<p class="font-mono text-xs uppercase tracking-[0.2em] text-accent">Venture</p>
		<h1 class="mt-4 font-display text-4xl font-semibold tracking-tight text-ink">
			Private company analysis
		</h1>
		<p class="mt-4 max-w-xl text-muted">
			Analysis of private, venture-stage technology companies.
		</p>

		{entries.length === 0 ? (
			<div class="mt-16 border-t border-border pt-10">
				<p class="font-mono text-xs uppercase tracking-wide text-muted">No published coverage yet</p>
				<p class="mt-2 text-muted">The first analysis is in progress. Check back soon.</p>
			</div>
		) : (
			<div class="mt-12 grid auto-rows-fr gap-4 sm:grid-cols-2 lg:grid-cols-3">
				{entries.map((entry, i) => (
					<a
						href={`/venture/${entry.id}`}
						class="ticker-card stagger-in relative flex flex-col rounded-lg border border-border bg-surface p-6"
						style={`--stagger-i: ${i}`}
					>
						<span class="font-mono text-4xl font-medium uppercase tracking-tight text-ink">
							{companyName(entry.data.title)}
						</span>
						{entry.data.stage && (
							<span class="mt-3 font-mono text-xs uppercase tracking-wide text-muted">
								{entry.data.stage}
							</span>
						)}
						{entry.data.sector && (
							<span class="mt-2 font-mono text-[11px] uppercase tracking-wide text-accent">
								{entry.data.sector}
							</span>
						)}
						<span class="mt-6 flex flex-1 flex-col justify-end">
							<span class="block border-t border-border pt-4">
								<span class="card-title block font-display text-sm font-medium leading-snug text-muted">
									{entry.data.title}
								</span>
								<span class="mt-2 block font-mono text-xs text-muted">
									{entry.data.date.toLocaleDateString('en-US', { year: 'numeric', month: 'short' })}
								</span>
							</span>
						</span>
					</a>
				))}
			</div>
		)}
	</section>
</Layout>

<style>
	.ticker-card {
		transition:
			transform 200ms ease-out,
			border-color 200ms ease-out;
	}

	.card-title {
		transition: color 200ms ease-out;
	}

	.ticker-card:focus-visible {
		border-color: var(--color-accent);
	}

	.ticker-card:focus-visible .card-title {
		color: var(--color-ink);
	}

	@media (hover: hover) {
		.ticker-card:hover,
		.ticker-card:focus-visible {
			transform: scale(1.04);
			border-color: var(--color-accent);
			z-index: 1;
		}

		.ticker-card:hover .card-title {
			color: var(--color-ink);
		}
	}
</style>
