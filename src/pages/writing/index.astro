---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const entries = (await getCollection('writing', ({ data }) => !data.draft)).sort(
	(a, b) => b.data.date.valueOf() - a.data.date.valueOf() || a.id.localeCompare(b.id)
);
---

<Layout title="Adam Jurdi: Writing">
	<section class="mx-auto max-w-3xl px-6 py-20">
		<p class="font-mono text-xs uppercase tracking-[0.2em] text-accent">Writing</p>
		<h1 class="mt-4 font-display text-4xl font-semibold tracking-tight text-ink">Explainers</h1>
		<p class="mt-4 max-w-xl text-muted">
			Semiconductor technology translated into what it means for the investment case.
		</p>

		{entries.length === 0 ? (
			<div class="mt-16 border-t border-border pt-10">
				<p class="font-mono text-xs uppercase tracking-wide text-muted">Nothing published yet</p>
				<p class="mt-2 text-muted">The first explainer is in progress. Check back soon.</p>
			</div>
		) : (
			<div class="mt-12 border-t border-border">
				{entries.map((entry) => (
					<a
						href={`/writing/${entry.id}`}
						class="grid grid-cols-[1fr_6rem] items-baseline gap-4 border-b border-border py-4 transition-colors hover:bg-ink/[0.03]"
					>
						<span class="font-display text-base text-ink">{entry.data.title}</span>
						<span class="font-mono text-xs text-muted">
							{entry.data.date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
						</span>
					</a>
				))}
			</div>
		)}
	</section>
</Layout>
